# Not needed for the normal on-prem build: the frontend is served same-origin
# from the FastAPI process (see client/dist mount in server/main.py), so
# api.js and WebSocketContext.jsx default to the current page's origin.
# Only set VITE_API_URL / VITE_WS_URL here if the frontend is hosted
# separately from the API (a split deployment).
# VITE_API_URL=https://your-api-host
# VITE_WS_URL=wss://your-api-host/ws
