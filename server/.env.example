# ── EmiratesCo Server — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# Option A: full URL (takes precedence)
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/EmiratesCo_Database

# Option B: individual components (used if DATABASE_URL is not set or is the default)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=EmiratesCo_Database
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development         # development | staging | production
DEBUG=true                      # Set to false in production
SECRET_KEY=change-me-in-production-use-a-long-random-string
LOG_LEVEL=INFO

# ── API Server ────────────────────────────────────────────────────────────────
# 127.0.0.1 for a standalone single-laptop shop install (no LAN access needed).
# Only use 0.0.0.0 if this specific shop has a second device that must reach it.
API_HOST=127.0.0.1
API_PORT=8000

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty for a normal on-prem
# shop install — the frontend is served same-origin from this same process
# (client/dist mount in main.py), so no cross-origin requests happen.
# Only needed for local dev (Vite) or a separately-hosted frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis (optional — for future caching) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email / SMTP (optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── File Uploads ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760          # 10 MB in bytes
UPLOAD_FOLDER=uploads
